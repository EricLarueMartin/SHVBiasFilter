[Unit]
Description=Agent project landing pages and SHV field backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__AGENT_USER__
Group=__AGENT_USER__
WorkingDirectory=__STATIC_ROOT__
ExecStart=/usr/bin/python3 __PROJECT_DIR__/software/bias_filter/field_backend.py --host 0.0.0.0 --port 80 --static-dir __STATIC_ROOT__ --job-dir __PROJECT_DIR__/simulations/axisymmetric/jobs --workers 1 --solver fd
Restart=on-failure
RestartSec=3
# Keep solver memory resident. FEniCSx subprocesses inherit this cgroup limit,
# preventing write-heavy swap activity on Raspberry Pi SD-card deployments.
MemorySwapMax=0
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=false

[Install]
WantedBy=multi-user.target
